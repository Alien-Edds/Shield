{
	"$schema": "https://raw.githubusercontent.com/Bedrock-OSS/regolith-schemas/main/config/v1.6.json",
	"author": "Alien Edds",
	"name": "Custom Shield",
	"packs": {
		"behaviorPack": "./packs/BP",
		"resourcePack": "./packs/RP"
	},
	"regolith": {
		"dataPath": "./packs/data",
		"filterDefinitions": {
			"fast_ts": {
				"url": "github.com/lightyisreal/regolith-filters",
				"version": "ce8cc237070ccfab7e884e5de60e5ced0f9049b1"
			},
			"mcaddon": {
				"url": "github.com/lightyisreal/regolith-filters",
				"version": "ce8cc237070ccfab7e884e5de60e5ced0f9049b1"
			}
		},
		"formatVersion": "1.6.0",
		"profiles": {
			"default": {
				"export": {
					"build": "standard",
					"readOnly": false,
					"target": "development"
				},
				"filters": [
					{
						"filter": "fast_ts"
					}
				]
			},
			"production": {
				"export": {
					"target": "local"
				},
				"filters": [
					{
						"profile": "default"
					},
					{
						"filter": "mcaddon"
					}
				]
			}
		}
	}
}