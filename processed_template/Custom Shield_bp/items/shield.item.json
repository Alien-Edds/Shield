{
    "format_version": "1.26.0",
    "minecraft:item": {
        "description": {
            "identifier": "custom_shield:custom_shield",
            "menu_category": {
                "category": "equipment",
                "is_hidden_in_commands": false
            }
        },
        "components": {
            "minecraft:allow_off_hand": true,
            "minecraft:durability": {
                "max_durability": 336
            },
            "minecraft:enchantable": {
                "slot": "elytra",
                "value": 15
            },
            "custom_shield:shield": {
                //optional block sound
                "block": "item.shield.block",
                //optional blocking delay in seconds
                "delay": 0.25,
                //optional command to run from the player on block
                // "command": "say hi",
                //optional sound to play when the shield is disabled
                "disable_sound": "random.break",
                //optional knockback
                "knockback": {
                    "x": 1.75,
                    "y": 0.4
                }
            },
            "minecraft:repairable": {
                "repair_items": [
                    {
                        "items": ["iron_ingot"],
                        "repair_amount": "c.this.max_durability * 0.25"
                    }
                ]
            },
            "minecraft:block_placer": {
                "block": "custom_shield:custom_shield",
                "replace_block_item": true
            },
            "minecraft:max_stack_size": 1,
            "minecraft:cooldown": {
                "category": "custom_shield:shield",
                "duration": 5
            }
        }
    }
}